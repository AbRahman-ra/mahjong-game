{
    "compilerOptions": {
        "lib": ["ESNext", "DOM"],
        "target": "ESNext",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "strict": true,
        "noEmit": true,
        "skipLibCheck": true,
        "jsx": "preserve",
        "types": ["bun"],
        "paths": { "@/*": ["./src/*"] }
    }
}
